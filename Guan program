<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<title>Menu Kopi</title>
<style>
    body {
        font-family: Arial, sans-serif;
        padding: 20px;
    }

    table {
        border-collapse: collapse;
        width: 100%;
        max-width: 500px;
    }

    th, td {
        border: 1px solid #ccc;
        padding: 10px;
        text-align: center;
    }

    th {
        background-color: #f5f5f5;
    }

    img {
        width: 100px;
        border-radius: 8px;
    }

    button {
        background-color: #25D366;
        color: white;
        border: none;
        padding: 8px 12px;
        cursor: pointer;
        border-radius: 5px;
    }

    button:hover {
        background-color: #1ebe5d;
    }

    input {
        width: 80px;
        text-align: center;
    }
</style>
</head>
<body>

<h2>Menu Minuman</h2>

<table>
    <tr>
        <th>Gambar</th>
        <th>Produk</th>
        <th>Harga</th>
        <th>Aksi</th>
    </tr>
    <tr>
        <td>
            <img src="https://via.placeholder.com/150?text=Kopi" alt="Kopi">
        </td>
        <td>Kopi</td>
        <td>
            <input type="text" id="harga" value="15000" readonly>
        </td>
        <td>
            <button onclick="shareWA()">Share WhatsApp</button>
        </td>
    </tr>
</table>

<script>
function shareWA() {
    let harga = document.getElementById("harga").value;
    let pesan = `Saya mau pesan Kopi dengan harga Rp ${harga}`;
    let url = "https://wa.me/?text=" + encodeURIComponent(pesan);
    window.open(url, "_blank");
}
</script>

</body>
</html>
